# Supabase / database
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# 친구도매
DOME_API_URL=https://79dome.com/Api/ProductSelect_Api_UTF8.php
DOME_API_ID=
DOME_API_KEY=
DOME_API_MOCK_MODE=false
DOME_API_TIMEOUT_MS=10000
DOME_API_MAX_RESPONSE_BYTES=5242880

# Cloudflare R2 (선택)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# GitHub Actions 상품 동기화 (선택)
GITHUB_ACTIONS_TOKEN=
GITHUB_ACTIONS_REPOSITORY=ssmh07-crypto/shoppingday
GITHUB_ACTIONS_WORKFLOW=product-sync.yml

# 네이버 커머스API (선택: SELF 애플리케이션 기준)
NAVER_COMMERCE_API_URL=https://api.commerce.naver.com/external
NAVER_COMMERCE_CLIENT_ID=
NAVER_COMMERCE_CLIENT_SECRET=
NAVER_COMMERCE_TOKEN_TYPE=SELF
NAVER_COMMERCE_ACCOUNT_ID=
NAVER_COMMERCE_TIMEOUT_MS=15000

# 운영 Worker -> 고정 IP 중계 서버 (설정 시 위 네이버 인증정보 대신 사용)
NAVER_COMMERCE_RELAY_URL=
# 로컬 Quick Tunnel 실행기가 Worker Secret으로 관리하는 우선 URL
NAVER_COMMERCE_RELAY_URL_OVERRIDE=
NAVER_COMMERCE_RELAY_SHARED_SECRET=

# 규칙 기반 상품·키워드 관리 (로컬 개발에서는 true로 전체 흐름 테스트 가능)
USE_MOCK_EXTERNAL_APIS=false

# 네이버 검색광고 키워드 도구
NAVER_SEARCH_AD_API_URL=https://api.searchad.naver.com
NAVER_SEARCH_AD_API_KEY=
NAVER_SEARCH_AD_SECRET_KEY=
NAVER_SEARCH_AD_CUSTOMER_ID=
NAVER_SEARCH_AD_TIMEOUT_MS=15000

# NAVER API HUB 쇼핑 인사이트 (선택 확장)
NAVER_API_HUB_BASE_URL=https://naverapihub.apigw.ntruss.com
NAVER_API_HUB_CLIENT_ID=
NAVER_API_HUB_CLIENT_SECRET=

# 키워드 관리 중앙 설정
KEYWORD_METRICS_CACHE_HOURS=24
KEYWORD_CANDIDATE_COUNT=30
GENERATED_TITLE_MAX_LENGTH=60
