{
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "cf:build": "opennextjs-cloudflare build",
    "cf:deploy": "OPEN_NEXT_DEPLOY=true wrangler deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run cf:build && npm run cf:deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs migrate",
    "import:all": "node --max-old-space-size=2048 --conditions=react-server --env-file=.env.local --import tsx scripts/import-dome-all.ts",
    "sync:products": "node --max-old-space-size=2048 --conditions=react-server --import tsx scripts/sync-dome-products.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.5",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.10.0",
    "iconv-lite": "^0.7.3",
    "next": "^16.2.6",
    "postgres": "^3.4.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sanitize-html": "^2.17.6",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
